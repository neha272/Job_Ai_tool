// Job Copilot data model. SQLite via Prisma 7 (driver adapter; url lives in prisma.config.ts).
// JSON-ish fields (baseFacts, fabricationFlags, detailsJson) are stored as String
// because SQLite has no native JSON/enum types — serialize with JSON.stringify in app code.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Resume {
  id           String        @id @default(cuid())
  label        String // "Base resume", "Tailored - Acme, Backend Engineer"
  isBase       Boolean       @default(false)
  texSource    String // raw LaTeX
  pdfPath      String?
  baseFacts    String? // JSON: employers/titles/dates/skills/numbers from the base resume, for the fabrication check
  createdAt    DateTime      @default(now())
  applications Application[]
}

model JobPosting {
  id               String        @id @default(cuid())
  source           String // "greenhouse" | "lever" | "ashby" | "manual"
  sourceRestricted Boolean       @default(false) // true for manual LinkedIn/Indeed: blocks automated submit, forces manual click-through
  company          String
  title            String
  location         String?
  url              String
  applyUrl         String?
  descriptionRaw   String
  fitScore         Int? // 0-100, from the Claude scoring pass
  discoveredAt     DateTime      @default(now())
  applications     Application[]
}

model Application {
  id               String     @id @default(cuid())
  jobId            String
  job              JobPosting @relation(fields: [jobId], references: [id])
  resumeId         String
  resume           Resume     @relation(fields: [resumeId], references: [id])
  method           String // "email" | "portal"
  status           String     @default("found") // found | tailoring | pending_review | approved | applied | interviewing | offer | rejected | withdrawn
  draftEmail       String?
  fabricationFlags String? // JSON array of anything the fabrication check flagged
  notes            String?
  appliedAt        DateTime?
  followUpAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Profile {
  id          String  @id @default("singleton")
  fullName    String  @default("")
  email       String  @default("")
  phone       String?
  linkedinUrl String?
  detailsJson String  @default("{}") // arbitrary form-field answers keyed by common field names, for portal autofill
}

model SourceConfig {
  id           String  @id @default(cuid())
  boardType    String // "greenhouse" | "lever" | "ashby"
  companyToken String // Greenhouse board token, Lever site name, Ashby job-board name
  active       Boolean @default(true)

  @@unique([boardType, companyToken])
}
