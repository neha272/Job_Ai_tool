# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# job-copilot: local database (never commit)
/dev.db
/dev.db-journal
/dev.db-wal
/dev.db-shm
*.db
*.db-journal

# job-copilot: generated Prisma client
/src/generated/

# job-copilot: Playwright persistent browser profiles (contain ATS logins)
/.userdata/

# job-copilot: compiled résumé PDFs and other local artifacts
/storage/

/src/generated/prisma
