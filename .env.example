# Job Copilot — environment variables.
# Copy this file to `.env` and fill in the blanks. `.env` is gitignored; never commit it.

# --- AI model for résumé tailoring + fit scoring. ---
# OPTIONAL. If ANTHROPIC_API_KEY is set, the app uses Claude (best quality).
# If it's left blank, the app falls back to a LOCAL model via Ollama — no key,
# free, private. Install Ollama (https://ollama.com), then: `ollama pull llama3`
# (or a longer-context model like `qwen2.5:7b`, and set OLLAMA_MODEL below).
ANTHROPIC_API_KEY=
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# --- Database (local SQLite file, managed by Prisma). ---
# Resolved relative to the repo root; always run `prisma` commands from the repo root.
DATABASE_URL="file:./dev.db"

# --- SMTP for sending application emails. Required from Phase 1 (email method). ---
# Gmail: enable 2-Step Verification, then create a 16-char App Password
# (https://myaccount.google.com/apppasswords) and paste it as SMTP_PASS.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
# The From address applications are sent from (usually the same as SMTP_USER).
MAIL_FROM=""

# --- Discovery schedule (Phase 4). node-cron expression + IANA timezone. ---
DISCOVERY_INTERVAL_CRON="*/30 * * * *"
TZ="America/Chicago"

# --- Portal automation (Phase 3). ---
# The apply browser runs headed (visible) by default so you can solve
# CAPTCHAs/logins and click Submit yourself. Set to 1 for headless testing only.
PORTAL_HEADLESS="0"
