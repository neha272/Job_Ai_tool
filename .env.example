# Job Copilot — environment variables.
# Copy this file to `.env` and fill in the blanks. `.env` is gitignored; never commit it.

# --- Anthropic (résumé tailoring + fit scoring). Required from Phase 1. ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Database (local SQLite file, managed by Prisma). ---
# Resolved relative to the repo root; always run `prisma` commands from the repo root.
DATABASE_URL="file:./dev.db"

# --- SMTP for sending application emails. Required from Phase 1 (email method). ---
# Gmail: enable 2-Step Verification, then create a 16-char App Password
# (https://myaccount.google.com/apppasswords) and paste it as SMTP_PASS.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
# The From address applications are sent from (usually the same as SMTP_USER).
MAIL_FROM=""

# --- Discovery schedule (Phase 4). node-cron expression + IANA timezone. ---
DISCOVERY_INTERVAL_CRON="*/30 * * * *"
TZ="America/Chicago"
